hs_err_pid*
replay_pid*

# Node.js / Vue 相关忽略规则
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
# 构建产物
dist/
build/
# 环境变量
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
# IDE 缓存（如果前端用 VS Code）
.vscode/
# 包管理锁文件（可选忽略，建议保留）
# package-lock.json
# yarn.lock
# pnpm-lock.yaml
